#: src/essoradesktop.c src/desktopicons.c
msgid "Could not open the X display"
msgstr "No s’ha pogut obrir la pantalla X"

#: src/essoradesktop.c src/desktopicons.c
msgid "EssoraWM Desktop Manager"
msgstr "Gestor de l’escriptori EssoraWM"

#: src/essoradesktop.c src/desktopicons.c
msgid "No application launchers were found"
msgstr "No s’han trobat llançadors d’aplicacions"

#: src/essoradesktop.c src/desktopicons.c
msgid "Select an application to add it to the desktop"
msgstr "Seleccioneu una aplicació per afegir-la a l’escriptori"

#: src/essoradesktop.c src/desktopicons.c
msgid "Move drive icons freely on the desktop or arrange them here"
msgstr "Moveu lliurement les icones de les unitats per l’escriptori o ordeneu-les aquí"

#: src/essoradesktop.c src/desktopicons.c
msgid "Default drive icon settings restored; press Apply"
msgstr "S’han restaurat els valors predeterminats de les icones d’unitats; premeu Aplica"

#: src/essoradesktop.c src/desktopicons.c
msgid "No applications match the search"
msgstr "Cap aplicació coincideix amb la cerca"

#: src/essoradesktop.c src/desktopicons.c
msgid "Could not create the PuppyPin configuration directory"
msgstr "No s’ha pogut crear la carpeta de configuració de PuppyPin"

#: src/essoradesktop.c src/desktopicons.c
msgid "Could not create PuppyPin"
msgstr "No s’ha pogut crear PuppyPin"

#: src/essoradesktop.c src/desktopicons.c
msgid "This application is already on the desktop"
msgstr "Aquesta aplicació ja és a l’escriptori"

#: src/essoradesktop.c src/desktopicons.c
msgid "PuppyPin is invalid: </pinboard> was not found"
msgstr "PuppyPin no és vàlid: no s’ha trobat </pinboard>"

#: src/essoradesktop.c src/desktopicons.c
msgid "Not enough memory to update PuppyPin"
msgstr "No hi ha prou memòria per actualitzar PuppyPin"

#: src/essoradesktop.c src/desktopicons.c
msgid "Could not write PuppyPin"
msgstr "No s’ha pogut escriure PuppyPin"

#: src/essoradesktop.c src/desktopicons.c
msgid "Added to the desktop. EssoraWM will save the new position when you move it"
msgstr "Afegida a l’escriptori. EssoraWM desarà la nova posició quan la moveu"

#: src/essoradesktop.c src/desktopicons.c
msgid "This application is not on the desktop"
msgstr "Aquesta aplicació no és a l’escriptori"

#: src/essoradesktop.c src/desktopicons.c
msgid "Removed from the desktop"
msgstr "Eliminada de l’escriptori"

#: src/essoradesktop.c src/desktopicons.c
msgid "Could not save drive icon settings"
